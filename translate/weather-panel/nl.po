#: packages/weather-panel/contents/config/config.qml:6
msgid "Weather"
msgstr "Weer"

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:78
msgid "Location"
msgstr "Plaats"

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:84
msgid ""
"Start typing a city name and pick a result to set your weather location."
msgstr ""
"Typ een plaatsnaam en klik het juiste resultaat aan om als locatie te "
"gebruiken."

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:93
msgid "City name (e.g. London)"
msgstr "Plaatsnaam (bijv. Amsterdam)"

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:143
msgid "Temperature unit:"
msgstr "Temperatuureenheid:"

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:148
msgid "Celsius (°C)"
msgstr "Voorvertoning: 20°C"

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:148
msgid "Fahrenheit (°F)"
msgstr "Imperiaal (°F, mpu, inHg, in)"

#: packages/weather-panel/contents/ui/config/ConfigGeneral.qml:164
msgid ""
"Locations are resolved with the Open-Meteo Geocoding API (geocoding-api.open-"
"meteo.com) and forecasts are fetched from Open-Meteo (api.open-meteo.com). "
"No account or API key is required. Selecting a result stores its coordinates "
"directly, so weather refreshes skip the geocoding step."
msgstr ""
"Er wordt naar plaatsen gezocht aan de hand van de Open-Meteo Geocoding-api "
"(geocoding-api.open-meteo.com). Weerberichten worden opgehaald van Open-"
"Meteo (api.open-meteo.com). Hiervoor is geen account of api-sleutel vereist. "
"Kies een resultaat om de coördinaten direct op te slaan."

